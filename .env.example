ANTHROPIC_API_KEY=your-key-here

# Job providers (optional — each is enabled only when its keys are present)

# Bundesagentur für Arbeit (BA) Jobsuche API
BA_API_KEY=your-ba-api-key
BA_BASE_URL=https://rest.arbeitsagentur.de/jobboerse/jobsuche-service

# Adzuna Jobs API — https://developer.adzuna.com/
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key
# Two-letter Adzuna country code (default: de)
ADZUNA_COUNTRY=de
